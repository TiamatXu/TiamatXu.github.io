{
  "compilerOptions": {
    "outDir": "dist",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@vuetheme/*": ["vuetheme/*"],
      "@vuetheme": ["vuetheme/index.ts"],
      "@theme/*": [".vitepress/theme/*"]
    }
  },
  "include": [
    ".vitepress/fetch-contributions.ts",
    "env.d.ts",
    "docs/**/*",
    ".vitepress/**/*"
  ],
}
